{
  "expo": {
    "name": "ReceiptSnap",
    "slug": "receiptsnap",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "receiptsnap",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0E7C66"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.receiptsnap.mobile",
      "infoPlist": {
        "NSCameraUsageDescription": "ReceiptSnap uses the camera to capture and scan your receipts.",
        "NSPhotoLibraryUsageDescription": "ReceiptSnap imports receipt photos and PDFs from your library.",
        "NSPhotoLibraryAddUsageDescription": "ReceiptSnap saves scanned receipt images to your library.",
        "NSLocationWhenInUseUsageDescription": "ReceiptSnap logs mileage for business trips using your location.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "app.receiptsnap.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0E7C66"
      },
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      [
        "expo-camera",
        {
          "cameraPermission": "ReceiptSnap uses the camera to capture and scan your receipts."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "ReceiptSnap imports receipt photos from your library."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "ReceiptSnap logs mileage for business trips using your location."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#0E7C66"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0E7C66",
          "image": "./assets/splash.png",
          "imageWidth": 200
        }
      ],
      "expo-asset",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "extractApiBaseUrl": "https://receiptsnap-proxy.onrender.com",
      "googleOAuthClientIdIos": "REPLACE_WITH_IOS_CLIENT_ID",
      "googleOAuthClientIdAndroid": "REPLACE_WITH_ANDROID_CLIENT_ID",
      "googleOAuthClientIdWeb": "REPLACE_WITH_WEB_CLIENT_ID",
      "microsoftOAuthClientId": "REPLACE_WITH_MS_CLIENT_ID",
      "iapProductId": "receiptsnap_unlock",
      "eas": {
        "projectId": "REPLACE_WITH_EAS_PROJECT_ID"
      }
    }
  }
}
