# ReceiptSnap proxy configuration. Copy to server/.env (or set in Render).

# --- Gemini (REQUIRED) ---
GEMINI_API_KEY=your_google_generative_language_api_key
GEMINI_MODEL=gemini-3.1-flash-lite
# Optional override of the REST base url:
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# --- Server ---
PORT=8787

# --- Device-token auth (REQUIRED in production) ---
# HMAC secret behind POST /device/register; X-Device-Token = HMAC-SHA256(deviceId, secret).
# Generate with: openssl rand -hex 32
# Unset in dev = insecure fixed fallback (warning logged); unset in production = server refuses to boot.
DEVICE_TOKEN_SECRET=

# --- Rate limiting (per device) ---
RATE_LIMIT_PER_DAY=50
RATE_LIMIT_LIFETIME=5000
# Per-IP backstops (registration mints identities; extract gets a safety cap):
REGISTER_PER_DAY_PER_IP=10
EXTRACT_PER_DAY_PER_IP=200
# Billing circuit breaker: total Gemini calls/day across ALL routes (429 when spent).
GLOBAL_DAILY_GEMINI_CAP=2000
# CORS origins for the Expo WEB build (browser). Comma-separated, or '*' for any
# (default). Native apps don't need this. e.g. https://app.receiptsnap.app,http://localhost:8081
CORS_ALLOW_ORIGINS=*
# Feature-request submissions per device per day (anti-spam on the durable store).
FEATURE_REQUESTS_PER_DAY=10

# --- Roadmap & feature requests (OPTIONAL — durable storage in Supabase) ---
# The ONLY persistent storage. Holds roadmap upvotes + private feature requests
# (never receipts; devices stored as a sha256 hash). Unset = GET /roadmap still
# serves curated items at zero votes, but voting/submitting return 503.
# Use a SECRET key — modern `sb_secret_...` from Project Settings → API keys →
# Secret keys (the legacy service_role JWT also works via SUPABASE_SERVICE_ROLE_KEY).
# It bypasses RLS, so keep it server-only — never ship it in the app.
# SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
# SUPABASE_SECRET_KEY=sb_secret_xxxxxxxx

# --- Email forwarding feature ---
# Shared secret your mail provider's webhook must send as X-Inbound-Secret
# (or ?secret= for providers like SendGrid Parse that can't set headers).
# Generate with: openssl rand -hex 32
# In production the /inbound-email route is DISABLED (503) until this is set.
# INBOUND_EMAIL_SECRET=replace_with_openssl_rand_hex_32
# Domain shown to users: user-<token>@<FORWARDING_DOMAIN>
FORWARDING_DOMAIN=inbox.receiptsnap.app
# How long email-ingested receipts live in the ephemeral pending queue (ms).
PENDING_TTL_MS=259200000
